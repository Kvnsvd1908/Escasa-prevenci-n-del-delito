# ---------------------------------------------------------------
# Base de datos — Supabase
# ---------------------------------------------------------------
# 1. Crea un proyecto en https://supabase.com (plan Free sirve).
# 2. En el dashboard: Project Settings → Database → "Connection string".
# 3. Copia las DOS variantes: "Transaction" (pooled, :6543) y "Session" o "Direct" (:5432).
# 4. Reemplaza [YOUR-PASSWORD] por la contraseña que elegiste al crear el proyecto.
#
# DATABASE_URL  → la usa la app en runtime (pooled, soporta muchas conexiones serverless).
# DIRECT_URL    → la usa Prisma para migrations / db push (conexión directa).
# ---------------------------------------------------------------

DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Alternativa sin Supabase (Postgres local):
# DATABASE_URL="postgresql://user:password@localhost:5432/predcrim?schema=public"
# DIRECT_URL="postgresql://user:password@localhost:5432/predcrim?schema=public"

# ---------------------------------------------------------------
# NextAuth v5 — genera un secreto con: openssl rand -base64 32
# ---------------------------------------------------------------
AUTH_SECRET="cambia-esto-por-un-secreto-aleatorio-largo"
AUTH_TRUST_HOST="true"

# ---------------------------------------------------------------
# Configuración del mapa (Leaflet) — centro por defecto
# Por defecto: Santiago de Chile. Cambia según tu ciudad.
# ---------------------------------------------------------------
NEXT_PUBLIC_MAP_CENTER_LAT="-33.4489"
NEXT_PUBLIC_MAP_CENTER_LNG="-70.6693"
NEXT_PUBLIC_MAP_ZOOM="12"
